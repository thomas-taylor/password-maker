<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PasswordMakerAvalonia"
             xmlns:pm="clr-namespace:PasswordMaker;assembly=PasswordMaker"
             xmlns:pmc="clr-namespace:PasswordMakerClient;assembly=PasswordMakerClient"
             x:DataType="pmc:PasswordMakerVm"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="700"
             x:Class="PasswordMakerAvalonia.Views.MainView"
             Loaded="UserControlLoaded">
	<UserControl.Resources>
		<controls:NullToDefaultConverter x:Key="NullToDefaultConverter" />
	</UserControl.Resources>

	<Grid Margin="10,5,10,5" Name="mainGrid">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- Left Panel -->
		<Grid Grid.Row="0" Grid.Column="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Border Grid.Row="0" Margin="0,0,4,0" CornerRadius="5" BorderThickness="3" BorderBrush="#d36407" Background="Transparent">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<!-- Options Selection -->
					<Grid Grid.Row="0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Options" Margin="8,9,25,9" FontSize="18" FontWeight="Bold" />
						<ComboBox Grid.Column="1" Margin="5" FontSize="12" HorizontalAlignment="Right"
                            ItemsSource="{Binding SavedOptions}"
                            SelectedItem="{Binding CurrentOptions}">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Name}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</Grid>

					<!-- Action Buttons -->
					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Button Grid.Column="1" Margin="5" Content="New" Click="NewOptionsButtonClick" />
						<Button Grid.Column="2" Margin="5" Content="Rename" Click="RenameOptionsButtonClick" />
						<Button Grid.Column="3" Margin="5" Content="Delete" Click="DeleteOptionsButtonClick" />
					</Grid>
				</Grid>
			</Border>

			<!-- Options Editor -->
			<controls:OptionsEditor Grid.Row="1" Name="optionsEditor" Margin="15,0,0,0" />
		</Grid>

		<!-- Right Panel -->
		<Grid Grid.Row="0" Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<Border Grid.Row="0" Margin="4,0,0,0" CornerRadius="5" BorderThickness="3" BorderBrush="#d36407" Background="Transparent">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<!-- Generate Section -->
					<Grid Grid.Row="0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Generate" Margin="8,9,25,9" FontSize="18" FontWeight="Bold" />
						<TextBlock Grid.Column="1" Text="Number" Margin="5" FontSize="12" TextAlignment="Right" VerticalAlignment="Center" />
						<NumericUpDown Grid.Column="2" Margin="5" FontSize="16" MinWidth="110"
                                       Minimum="1" FormatString="F0"
                                       Value="{Binding NumberToGenerate, Mode=TwoWay, Converter={StaticResource NullToDefaultConverter}}" />
					</Grid>

					<!-- Action Buttons -->
					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Button Grid.Column="1" Margin="5" Content="Generate" Click="GenerateButtonClick" />
						<Button Grid.Column="2" Margin="5" Content="Copy" Click="CopyToClipboardButtonClick" />
					</Grid>
				</Grid>
			</Border>

			<!-- Generated Text -->
			<TextBox Grid.Row="1" TextWrapping="Wrap" Margin="5,10,5,10" AcceptsReturn="True"
                     FontSize="16" FontFamily="Consolas" Name="generatedTextBox" />
		</Grid>
	</Grid>
</UserControl>